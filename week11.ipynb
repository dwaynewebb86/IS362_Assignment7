    "import requests\n",
    "import pandas as pd\n",
    "\n",
    "\n",
    "def main():\n",
    "    api_key = 
    "\n",
    "    url = \"https://api.nytimes.com/svc/news/v3/content/nyt/business.json\"\n",
    "    params = {\n",
    "        \"api-key\": api_key\n",
    "    }\n",
    "\n",
    "    response = requests.get(url, params=params)\n",
    "    response.raise_for_status()\n",
    "\n",
    "    data = response.json()\n",
    "    articles = data[\"results\"]\n",
    "\n",
    "    df = pd.DataFrame(articles)\n",
    "\n",
    "    # Select useful columns\n",
    "    df = df[[\n",
    "        \"title\",\n",
    "        \"abstract\",\n",
    "        \"byline\",\n",
    "        \"section\",\n",
    "        \"published_date\",\n",
    "        \"url\"\n",
    "    ]]\n",
    "\n",
    "    print(df.head())\n",
    "    print(df.columns)\n",
    "\n",
    "\n",
    "if __name__ == \"__main__\":\n",
    "    main()"
   ]
